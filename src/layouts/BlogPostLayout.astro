---
import BaseLayout from './BaseLayout.astro';
import ThreeBackground from '../components/ThreeBackground.astro';
import Navigation from '../components/Navigation.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date | undefined;
  tags?: string[] | undefined;
  readingTime?: number | undefined;
}

const base = import.meta.env.BASE_URL;
const { title, description, pubDate, updatedDate, tags, readingTime } = Astro.props;

const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} - bl0xsmith`} description={description}>
  <ThreeBackground />
  <Navigation />

  <article class="blog-post">
    <div class="container">
      <header class="post-header">
        <a href={`${base}blog`} class="back-link">← Back to Blog</a>
        <h1 class="post-title shimmer-text">{title}</h1>
        <div class="post-meta">
          <time class="post-date">{formattedPubDate}</time>
          {readingTime && (
            <span class="post-reading-time">{readingTime} min read</span>
          )}
          {formattedUpdatedDate && (
            <span class="post-updated">Updated: {formattedUpdatedDate}</span>
          )}
        </div>
        {tags && tags.length > 0 && (
          <div class="post-tags">
            {tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </header>

      <div class="post-content">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    min-height: 100vh;
    padding: 8rem 2rem 5rem;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
  }

  .post-header {
    margin-bottom: 3rem;
    animation: fadeInDown 1s ease-out;
  }

  .back-link {
    display: inline-block;
    color: var(--color-accent-purple);
    text-decoration: none;
    margin-bottom: 2rem;
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .back-link:hover {
    transform: translateX(-5px);
    color: var(--color-accent-pink);
  }

  .post-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .post-meta {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1rem;
    font-size: 0.875rem;
  }

  .post-date {
    color: var(--color-accent-purple);
    font-weight: 500;
  }

  .post-updated {
    color: var(--color-text-dim);
  }

  .post-reading-time {
    color: var(--color-text-dim);
    padding: 0.1rem 0.5rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--glass-border);
    border-radius: 0.25rem;
    font-size: 0.8rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tag {
    padding: 0.25rem 0.75rem;
    background: var(--color-surface-violet);
    border: 1px solid var(--color-border-violet);
    border-radius: 0.25rem;
    font-size: 0.75rem;
    color: var(--color-accent-purple);
  }

  .post-content {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-violet-subtle);
    border-radius: 1rem;
    padding: 3rem;
    animation: fadeInUp 1s ease-out 0.2s backwards;
  }

  .post-content :global(h1),
  .post-content :global(h2),
  .post-content :global(h3),
  .post-content :global(h4) {
    color: var(--color-text);
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .post-content :global(h2) {
    font-size: 2rem;
    background: linear-gradient(135deg, var(--color-accent-purple), var(--color-accent-pink));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .post-content :global(h3) {
    font-size: 1.5rem;
  }

  .post-content :global(p) {
    line-height: 1.8;
    margin-bottom: 1.5rem;
    color: var(--color-text-dim);
  }

  .post-content :global(a) {
    color: var(--color-accent-purple);
    text-decoration: none;
    border-bottom: 1px solid var(--color-accent-purple);
    transition: all 0.3s ease;
  }

  .post-content :global(a:hover) {
    color: var(--color-accent-pink);
    border-color: var(--color-accent-pink);
  }

  .post-content :global(code) {
    background: var(--color-surface-violet);
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
    font-family: 'Courier New', monospace;
    font-size: 0.9em;
    color: var(--color-accent-purple);
  }

  .post-content :global(pre) {
    background: var(--color-bg-darker);
    border: 1px solid var(--color-border-violet);
    border-radius: 0.5rem;
    padding: 1.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
    color: var(--color-text);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 1.5rem 0;
    padding-left: 2rem;
    color: var(--color-text-dim);
  }

  .post-content :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  .post-content :global(blockquote) {
    border-left: 4px solid var(--color-accent-purple);
    padding-left: 1.5rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-text-dim);
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .post-content {
      padding: 2rem 1.5rem;
    }
  }

  :global(pre) {
    position: relative;
  }

  :global(.copy-btn) {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    padding: 0.25rem 0.65rem;
    font-size: 0.72rem;
    font-family: var(--font-body);
    font-weight: 500;
    color: var(--color-text-dim);
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0.375rem;
    cursor: pointer;
    transition: all 0.15s ease;
    line-height: 1.4;
  }

  :global(.copy-btn:hover) {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.2);
  }

  :global(.copy-btn.copied) {
    color: #4ade80;
    border-color: rgba(74, 222, 128, 0.3);
  }
</style>

<script>
  function initCopyButtons() {
    document.querySelectorAll('pre').forEach((pre) => {
      if (pre.querySelector('.copy-btn')) return;
      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.textContent = 'Copy';
      pre.appendChild(btn);
      btn.addEventListener('click', () => {
        const code = pre.querySelector('code');
        navigator.clipboard.writeText(code?.textContent ?? '').then(() => {
          btn.textContent = 'Copied!';
          btn.classList.add('copied');
          setTimeout(() => {
            btn.textContent = 'Copy';
            btn.classList.remove('copied');
          }, 2000);
        });
      });
    });
  }
  document.addEventListener('astro:page-load', initCopyButtons);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCopyButtons);
  } else {
    initCopyButtons();
  }
</script>
