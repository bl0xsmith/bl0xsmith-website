---
import BaseLayout from './BaseLayout.astro';
import ThreeBackground from '../components/ThreeBackground.astro';
import Navigation from '../components/Navigation.astro';

interface Props {
  title: string;
  description: string;
  tags?: string[] | undefined;
  image?: string | undefined;
  link?: string | undefined;
  github?: string | undefined;
}

const base = import.meta.env.BASE_URL;
const { title, description, tags, image, link, github } = Astro.props;
const imageSrc = image?.startsWith('/') ? `${base}${image.slice(1)}` : image;
---

<BaseLayout title={`${title} - bl0xsmith`} description={description}>
  <ThreeBackground />
  <Navigation />

  <article class="project-post">
    <div class="container">
      <header class="post-header">
        <a href={`${base}projects`} class="back-link">← Back to Projects</a>
        <h1 class="post-title shimmer-text">{title}</h1>

        {tags && tags.length > 0 && (
          <div class="post-tags">
            {tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}

        {imageSrc && (
          <div class="post-hero-image">
            <img src={imageSrc} alt={title} loading="lazy" />
          </div>
        )}

        {(link || github) && (
          <div class="post-links">
            {link && (
              <a href={link} class="post-link" target="_blank" rel="noopener noreferrer">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                  <polyline points="15 3 21 3 21 9"></polyline>
                  <line x1="10" y1="14" x2="21" y2="3"></line>
                </svg>
                Live Demo
              </a>
            )}
            {github && (
              <a href={github} class="post-link" target="_blank" rel="noopener noreferrer">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
                </svg>
                GitHub
              </a>
            )}
          </div>
        )}
      </header>

      <div class="post-content">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .project-post {
    min-height: 100vh;
    padding: 8rem 2rem 5rem;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
  }

  .post-header {
    margin-bottom: 3rem;
    animation: fadeInDown 1s ease-out;
  }

  .back-link {
    display: inline-block;
    color: var(--color-accent-purple);
    text-decoration: none;
    margin-bottom: 2rem;
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .back-link:hover {
    transform: translateX(-5px);
    color: var(--color-accent-pink);
  }

  .post-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .tag {
    padding: 0.25rem 0.75rem;
    background: var(--color-surface-violet);
    border: 1px solid var(--color-border-violet);
    border-radius: 0.25rem;
    font-size: 0.75rem;
    color: var(--color-accent-purple);
  }

  .post-hero-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 0.75rem;
    overflow: hidden;
    margin-bottom: 1.5rem;
    background: var(--color-bg-darker);
  }

  .post-hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .post-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    background: var(--color-surface-violet);
    border: 1px solid var(--color-border-violet);
    border-radius: 0.5rem;
    color: var(--color-accent-purple);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .post-link:hover {
    background: var(--color-accent-purple);
    color: white;
    border-color: var(--color-accent-purple);
  }

  .post-content {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-violet-subtle);
    border-radius: 1rem;
    padding: 3rem;
    animation: fadeInUp 1s ease-out 0.2s backwards;
  }

  .post-content :global(h1),
  .post-content :global(h2),
  .post-content :global(h3),
  .post-content :global(h4) {
    color: var(--color-text);
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .post-content :global(h2) {
    font-size: 2rem;
    background: linear-gradient(135deg, var(--color-accent-purple), var(--color-accent-pink));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .post-content :global(h3) {
    font-size: 1.5rem;
  }

  .post-content :global(p) {
    line-height: 1.8;
    margin-bottom: 1.5rem;
    color: var(--color-text-dim);
  }

  .post-content :global(a) {
    color: var(--color-accent-purple);
    text-decoration: none;
    border-bottom: 1px solid var(--color-accent-purple);
    transition: all 0.3s ease;
  }

  .post-content :global(a:hover) {
    color: var(--color-accent-pink);
    border-color: var(--color-accent-pink);
  }

  .post-content :global(code) {
    background: var(--color-surface-violet);
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
    font-family: 'Courier New', monospace;
    font-size: 0.9em;
    color: var(--color-accent-purple);
  }

  .post-content :global(pre) {
    background: var(--color-bg-darker);
    border: 1px solid var(--color-border-violet);
    border-radius: 0.5rem;
    padding: 1.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
    color: var(--color-text);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 1.5rem 0;
    padding-left: 2rem;
    color: var(--color-text-dim);
  }

  .post-content :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  .post-content :global(blockquote) {
    border-left: 4px solid var(--color-accent-purple);
    padding-left: 1.5rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-text-dim);
  }

  .post-content :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .post-content {
      padding: 2rem 1.5rem;
    }
  }
</style>
