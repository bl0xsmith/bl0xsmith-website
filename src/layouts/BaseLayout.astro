---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Footer from '../components/Footer.astro';
import CommandPalette from '../components/CommandPalette.astro';

interface Props {
  title?: string;
  description?: string;
}

const base = import.meta.env.BASE_URL;
const {
  title = 'bl0xsmith',
  description = 'AI automation, trading systems, and blockchain engineering'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="bl0xsmith" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url} />
    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@bl0xsmith" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <!-- Google Fonts: Plus Jakarta Sans + Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <div class="cursor-follower"></div>
    <CommandPalette />
    <canvas id="three-canvas"></canvas>
    <div id="page-content">
      <slot />
      <Footer />
    </div>

    <style>
      #three-canvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -1;
        pointer-events: none;
      }

      #page-content {
        position: relative;
        z-index: 1;
      }

      /* Scroll reveal */
      [data-reveal] {
        opacity: 0;
        transform: translateY(24px);
        transition: opacity 0.55s ease, transform 0.55s ease;
      }
      [data-reveal].visible {
        opacity: 1;
        transform: translateY(0);
      }
      @media (prefers-reduced-motion: reduce) {
        [data-reveal] {
          opacity: 1;
          transform: none;
          transition: none;
        }
      }

      /* Custom cursor — do not transition left/top; position must track instantly */
      .cursor-follower {
        width: 20px;
        height: 20px;
        border: 1px solid rgba(79, 101, 245, 0.5);
        border-radius: 50%;
        position: fixed;
        pointer-events: none;
        z-index: 9999;
        transition:
          width 0.1s ease,
          height 0.1s ease,
          background-color 0.1s ease,
          opacity 0.12s ease;
        transform: translate(-50%, -50%);
      }

      .cursor-follower::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 3px;
        height: 3px;
        background: var(--color-primary);
        border-radius: 50%;
      }
    </style>

    <script>
      // Scroll reveal via IntersectionObserver
      function initReveal() {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.08 }
        );
        document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));
      }
      document.addEventListener('astro:page-load', initReveal);

      // Custom cursor: instant position, hide when pointer leaves window, re-bind hovers on nav
      let cursorCoreBound = false;
      let hoverAbort: AbortController | null = null;

      function getCursorEl(): HTMLElement | null {
        return document.querySelector('.cursor-follower');
      }

      function onCursorMouseMove(e: MouseEvent) {
        const cursor = getCursorEl();
        if (!cursor) return;
        cursor.style.left = `${e.clientX}px`;
        cursor.style.top = `${e.clientY}px`;
        cursor.style.opacity = '1';
      }

      function onCursorDocumentMouseOut(e: MouseEvent) {
        if (e.relatedTarget) return;
        const cursor = getCursorEl();
        if (cursor) cursor.style.opacity = '0';
      }

      function onCursorDocumentMouseOver(e: MouseEvent) {
        if (e.relatedTarget !== null) return;
        const cursor = getCursorEl();
        if (cursor) cursor.style.opacity = '1';
      }

      function onCursorVisibilityChange() {
        if (document.visibilityState !== 'visible') return;
        const cursor = getCursorEl();
        if (cursor) cursor.style.opacity = '1';
      }

      function initCursor() {
        const cursor = getCursorEl();
        if (!cursor) return;

        if (!cursorCoreBound) {
          cursorCoreBound = true;
          document.addEventListener('mousemove', onCursorMouseMove);
          document.addEventListener('mouseout', onCursorDocumentMouseOut);
          document.addEventListener('mouseover', onCursorDocumentMouseOver);
          document.addEventListener('visibilitychange', onCursorVisibilityChange);
        }

        hoverAbort?.abort();
        hoverAbort = new AbortController();
        const { signal } = hoverAbort;

        document.querySelectorAll('a, button, .card').forEach((el) => {
          el.addEventListener(
            'mouseenter',
            () => {
              cursor.style.width = '36px';
              cursor.style.height = '36px';
              cursor.style.backgroundColor = 'rgba(79, 101, 245, 0.1)';
            },
            { signal }
          );
          el.addEventListener(
            'mouseleave',
            () => {
              cursor.style.width = '20px';
              cursor.style.height = '20px';
              cursor.style.backgroundColor = 'transparent';
            },
            { signal }
          );
        });
      }

      document.addEventListener('astro:page-load', initCursor);
      initCursor();
    </script>
  </body>
</html>
