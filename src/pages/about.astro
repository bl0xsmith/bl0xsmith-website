---
import BaseLayout from '../layouts/BaseLayout.astro';
import ThreeBackground from '../components/ThreeBackground.astro';
import Navigation from '../components/Navigation.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="About - bl0xsmith" description="Staff-level engineer specializing in AI automation, trading systems, and blockchain development">
  <ThreeBackground />
  <Navigation />

  <main class="about-page">
    <div class="container">
      <h1 class="page-title">About Me</h1>

      <div class="content-grid">
        <section class="content-section intro-section" data-reveal>
          <h2>Who are you?</h2>
          <p>
            I'm bl0xsmith — a staff-level engineer who builds trading automation, on-chain systems, and AI agents.
            The kind of infrastructure that moves real money in production. I've shipped perpetuals trading products
            that became the #1 revenue driver, and driven DeFi products to $175M+ TVL across various employers.
          </p>
          <p>
            In parallel, I've been building Metatron Automata, an agentic trading platform that runs across crypto, forex, equities, and perps markets.
          </p>
          <p>
            Here I write about what I'm building and what I'm learning — build logs from Metatron, strategy teardowns from my own trading, 
            and deep dives on the AI, blockchain, and automation systems behind it all.
          </p>
        </section>

        <section class="content-section" data-reveal>
          <h2>Experience</h2>
          <div class="experience-list">
            <div class="exp-card">
              <div class="exp-header">
                <div class="exp-role">Senior Software Engineer II, Advanced Trading / Money</div>
                <div class="exp-company">ConsenSys &mdash; MetaMask</div>
                <div class="exp-period">Feb 2024 &ndash; Present</div>
              </div>
              <ul class="exp-bullets">
                <li>Launched MetaMask Perps — became #1 company-wide revenue driver within ~4 months</li>
                <li>Built core trading flow: market/limit orders, TP/SL, margin/leverage, liquidation & risk</li>
                <li>Delivered real-time P&L, price feeds, execution, and reconciliation across mobile & extension</li>
                <li>Drove MetaMask Earn to $175M+ TVL, achieving 73% of annual target in 1 month</li>
                <li>Launched ETH staking — 146K+ ETH staked since release</li>
              </ul>
            </div>

            <div class="exp-card">
              <div class="exp-header">
                <div class="exp-role">Metatron Automata</div>
                <div class="exp-company">Personal Project</div>
                <div class="exp-period">Feb 2021 &ndash; Present</div>
              </div>
              <ul class="exp-bullets">
                <li>Agentic automated trading platform across crypto, forex, equities, and perps</li>
                <li>Event-driven architecture streaming price, volume, and sentiment signals into agent-capable strategies</li>
                <li>Modular signal/execution engine with real-time P&L, reconciliation, and risk guardrails</li>
              </ul>
            </div>

            <div class="exp-card">
              <div class="exp-header">
                <div class="exp-role">Senior Backend Software Engineer</div>
                <div class="exp-company">PROOF / Moonbirds (acquired by Yuga Labs)</div>
                <div class="exp-period">Jan 2023 &ndash; Oct 2023</div>
              </div>
              <ul class="exp-bullets">
                <li>Optimized core contract listener micro-service — 96.88% memory reduction, scaled from ~10 to 100s of contracts</li>
                <li>Migrated micro-service architecture to NestJS, improving modularity and maintainability</li>
              </ul>
            </div>

            <div class="exp-card">
              <div class="exp-header">
                <div class="exp-role">Finance Engineering Team Lead</div>
                <div class="exp-company">BitPay</div>
                <div class="exp-period">Sept 2018 &ndash; Nov 2021</div>
              </div>
              <ul class="exp-bullets">
                <li>Launched payment protocol integrations for Litecoin, Dogecoin, and XRP</li>
                <li>Delivered Ripple (XRP) integration on schedule — contributing to a multi-million-dollar reward</li>
                <li>Built Banking API Suite to automate merchant fiat payouts with idempotent settlement flows</li>
              </ul>
            </div>
          </div>
        </section>

        <section class="content-section" data-reveal>
          <h2>What I Do</h2>
          <div class="what-i-do-grid">
            <div class="service-card">
              <div class="service-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
                </svg>
              </div>
              <h3>Trading Automation</h3>
              <p>Designing and shipping event-driven trading infrastructure — execution engines, signal processing, real-time P&L, and risk controls across crypto, forex, and perps.</p>
            </div>
            <div class="service-card">
              <div class="service-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                </svg>
              </div>
              <h3>Blockchain Development</h3>
              <p>Building DeFi products, smart contracts, and on-chain integrations across Ethereum, Solana, and Bitcoin. Deep experience with wallets, EVM, and protocol-level work.</p>
            </div>
            <div class="service-card">
              <div class="service-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"></circle>
                  <circle cx="12" cy="12" r="6"></circle>
                  <circle cx="12" cy="12" r="2"></circle>
                </svg>
              </div>
              <h3>AI Engineering</h3>
              <p>Architecting agentic systems, LLM tooling, and AI-first automation pipelines. Currently applying AI to market signal analysis, strategy execution, and trading infrastructure.</p>
            </div>
            <div class="service-card">
              <div class="service-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect>
                  <rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect>
                  <line x1="6" y1="6" x2="6.01" y2="6"></line>
                  <line x1="6" y1="18" x2="6.01" y2="18"></line>
                </svg>
              </div>
              <h3>Full Stack Engineering</h3>
              <p>End-to-end delivery across backend services (NestJS, Node, Postgres), mobile (React Native), and web (React, Astro) with a bias toward clean architecture and production reliability.</p>
            </div>
          </div>
        </section>

        <section class="content-section cta-section" data-reveal>
          <h2>Let's Connect</h2>
          <p>Currently open to interesting problems — reach me at <a href="mailto:hi@bl0xsmith.com">hi@bl0xsmith.com</a></p>
          <div class="contact-buttons">
            <a href={`${base}projects`} class="btn btn-primary">
              View My Work
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" st*roke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
            <a href={`${base}blog`} class="btn btn-secondary">Read My Blog</a>
          </div>
        </section>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .about-page {
    min-height: 100vh;
    padding: calc(var(--nav-height) + 2rem) 2rem 5rem;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
  }

  .page-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 700;
    text-align: center;
    margin-bottom: 3rem;
    color: var(--color-text);
  }

  .content-grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .content-section {
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
    border-radius: 1rem;
    padding: 2rem;
  }

  .content-section h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  .content-section p {
    line-height: 1.7;
    color: var(--color-text-dim);
    margin-bottom: 1rem;
  }

  .content-section p:last-of-type {
    margin-bottom: 0;
  }

  .experience-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 1rem;
  }

  .exp-card {
    padding: 1.25rem;
    background: var(--color-surface-primary-subtle);
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    transition: border-color 0.2s ease;
  }

  .exp-card:hover {
    border-color: var(--color-primary);
  }

  .exp-header {
    margin-bottom: 0.875rem;
  }

  .exp-role {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.2rem;
  }

  .exp-company {
    font-size: 0.9rem;
    color: var(--color-primary);
    font-weight: 500;
    margin-bottom: 0.2rem;
  }

  .exp-period {
    font-size: 0.8rem;
    color: var(--color-text-dim);
  }

  .exp-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .exp-bullets li {
    font-size: 0.875rem;
    color: var(--color-text-dim);
    line-height: 1.5;
    padding-left: 1rem;
    position: relative;
  }

  .exp-bullets li::before {
    content: '//';
    position: absolute;
    left: 0;
    color: var(--color-accent-purple);
    font-weight: 600;
    font-size: 0.75rem;
    top: 1px;
  }

  .what-i-do-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .service-card {
    padding: 1.25rem;
    background: var(--color-surface-primary-subtle);
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .service-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 20px var(--color-glow-primary);
  }

  .service-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface-primary);
    border-radius: 0.5rem;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  .service-card h3 {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .service-card p {
    font-size: 0.875rem;
    color: var(--color-text-dim);
    margin: 0;
    line-height: 1.5;
  }

  .cta-section {
    text-align: center;
  }

  .cta-section p {
    margin-bottom: 1.5rem;
  }

  .contact-buttons {
    margin-top: 1.5rem;
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    font-size: 1rem;
    font-weight: 600;
    font-family: var(--font-body);
    text-decoration: none;
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
    box-shadow: 0 4px 14px var(--color-btn-shadow);
  }

  .btn-primary:hover {
    background: var(--color-primary-dark);
    box-shadow: 0 6px 20px var(--color-btn-shadow-hover);
  }

  .btn-primary svg {
    transition: transform 0.2s ease;
  }

  .btn-primary:hover svg {
    transform: translateX(4px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    background: var(--color-surface-primary);
    border-color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .about-page {
      padding-top: calc(var(--nav-height) + 1rem);
    }

    .what-i-do-grid {
      grid-template-columns: 1fr;
    }

    .contact-buttons {
      flex-direction: column;
      align-items: center;
    }

    .btn {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }
  }
</style>
