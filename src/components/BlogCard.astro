---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
}

const { title, description, pubDate, slug, tags } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="blog-card">
  <a href={`/blog/${slug}`} class="blog-card-link">
    <div class="blog-card-content">
      <time class="blog-date">{formattedDate}</time>
      <h3 class="blog-title">{title}</h3>
      <p class="blog-description">{description}</p>
      {tags && tags.length > 0 && (
        <div class="blog-tags">
          {tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </div>
    <div class="blog-card-glow"></div>
  </a>
</article>

<style>
  .blog-card {
    position: relative;
    height: 100%;
  }

  .blog-card-link {
    display: block;
    height: 100%;
    background: var(--color-bg-card);
    border: 1px solid rgba(168, 85, 247, 0.2);
    border-radius: 1rem;
    padding: 2rem;
    text-decoration: none;
    color: var(--color-text);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .blog-card-link::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.1), rgba(236, 72, 153, 0.1));
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .blog-card-link:hover::before {
    opacity: 1;
  }

  .blog-card-link:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(168, 85, 247, 0.3);
    border-color: var(--color-accent-purple);
  }

  .blog-card-content {
    position: relative;
    z-index: 1;
  }

  .blog-date {
    display: block;
    font-size: 0.875rem;
    color: var(--color-accent-purple);
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .blog-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    background: linear-gradient(135deg, var(--color-accent-purple), var(--color-accent-pink));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .blog-description {
    color: var(--color-text-dim);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    padding: 0.25rem 0.75rem;
    background: rgba(168, 85, 247, 0.1);
    border: 1px solid rgba(168, 85, 247, 0.3);
    border-radius: 0.25rem;
    font-size: 0.75rem;
    color: var(--color-accent-purple);
  }

  .blog-card-glow {
    position: absolute;
    bottom: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.2), transparent 70%);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .blog-card-link:hover .blog-card-glow {
    opacity: 1;
  }
</style>
