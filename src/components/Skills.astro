---
// Skills/Tech Stack section
---

<section class="skills">
  <div class="container">
    <h2 class="section-title">Skills & Technologies</h2>
    <p class="section-subtitle">The various technologies behind AI automation, trading systems, and blockchain engineering</p>

    <div class="skills-grid" data-reveal>
      <div class="skill-category">
        <div class="category-header">
          <div class="category-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
            </svg>
          </div>
          <h3 class="category-title">Trading & Automation</h3>
        </div>
        <div class="skill-list">
          <span class="skill-tag">Perps / Derivatives</span>
          <span class="skill-tag">Forex</span>
          <span class="skill-tag">Crypto Markets</span>
          <span class="skill-tag">Event-Driven Architecture</span>
          <span class="skill-tag">TP/SL & Risk Controls</span>
          <span class="skill-tag">Real-Time P&L</span>
          <span class="skill-tag">Real-Time Signal Processing</span>
          <span class="skill-tag">Advanced Order Execution</span>
          <span class="skill-tag">Temporal Workflows</span>
          <span class="skill-tag">Claude</span>
        </div>
      </div>

      <div class="skill-category">
        <div class="category-header">
          <div class="category-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
            </svg>
          </div>
          <h3 class="category-title">Blockchain & Web3</h3>
        </div>
        <div class="skill-list">
          <span class="skill-tag">Ethereum</span>
          <span class="skill-tag">Bitcoin</span>
          <span class="skill-tag">Solana</span>
          <span class="skill-tag">Smart Contract Integration</span>
          <span class="skill-tag">Wallet Integration</span>
          <span class="skill-tag">DeFi Protocol Integration</span>
        </div>
      </div>

      <div class="skill-category">
        <div class="category-header">
          <div class="category-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <circle cx="12" cy="12" r="6"></circle>
              <circle cx="12" cy="12" r="2"></circle>
            </svg>
          </div>
          <h3 class="category-title">AI Engineering</h3>
        </div>
        <div class="skill-list">
          <span class="skill-tag">Cursor</span>
          <span class="skill-tag">Antigravity</span>
          <span class="skill-tag">Claude</span>
          <span class="skill-tag">Codex</span>
          <span class="skill-tag">AI Agents</span>
          <span class="skill-tag">Agentic Orchestration</span>
          <span class="skill-tag">LLMs</span>
          <span class="skill-tag">Embeddings</span>
          <span class="skill-tag">Agentic Systems</span>
          <span class="skill-tag">Prompt Engineering</span>
          <span class="skill-tag">AI Tooling</span>
        </div>
      </div>

      <div class="skill-category">
        <div class="category-header">
          <div class="category-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect>
              <rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect>
              <line x1="6" y1="6" x2="6.01" y2="6"></line>
              <line x1="6" y1="18" x2="6.01" y2="18"></line>
            </svg>
          </div>
          <h3 class="category-title">Backend & Infra</h3>
        </div>
        <div class="skill-list">
          <span class="skill-tag">TypeScript</span>
          <span class="skill-tag">Node.js</span>
          <span class="skill-tag learning">Rust</span>
          <span class="skill-tag">NestJS</span>
          <span class="skill-tag">Postgres</span>
          <span class="skill-tag">MongoDB</span>
          <span class="skill-tag">AWS</span>
          <span class="skill-tag">GCP</span>
          <span class="skill-tag">Docker</span>
          <span class="skill-tag">Kubernetes</span>
          <span class="skill-tag">Event-Driven Architecture</span>
          <span class="skill-tag">Micro-services</span>
          <span class="skill-tag">API Design</span>
          <span class="skill-tag">API Documentation</span>
          <span class="skill-tag">API Testing</span>
          <span class="skill-tag">API Observability</span>
        </div>
      </div>

      <div class="skill-category learning-category">
        <div class="category-header">
          <div class="category-icon learning">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"></polyline>
              <polyline points="8 6 2 12 8 18"></polyline>
            </svg>
          </div>
          <h3 class="category-title">Frontend & Mobile</h3>
        </div>
        <div class="skill-list">
          <span class="skill-tag">React</span>
          <span class="skill-tag">React Native</span>
          <span class="skill-tag">Astro</span>
          <span class="skill-tag">Tailwind CSS</span>
          <span class="skill-tag">Tanstack Query</span>
          <span class="skill-tag">TypeScript</span>
          <span class="skill-tag">Next.js</span>
          <span class="skill-tag">Angular</span>
          <span class="skill-tag">Vue.js</span>
          <span class="skill-tag">Extensions (Chrome / Firefox)</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .skills {
    padding: 6rem 2rem;
    position: relative;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    text-align: center;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-dim);
    font-size: 1.1rem;
    margin-bottom: 3rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .skill-category {
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
    border-radius: 1rem;
    padding: 1.5rem;
    transition: all 0.25s ease;
    cursor: pointer;
  }

  .skill-category:hover {
    background: var(--glass-bg-hover);
    border-color: var(--glass-border-hover);
    box-shadow: var(--glass-shadow-hover);
  }

  .category-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .category-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface-primary);
    border-radius: 0.5rem;
    color: var(--color-primary);
  }

  .category-icon.learning {
    background: var(--color-surface-primary);
    color: var(--color-primary);
  }

  .category-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .skill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tag {
    padding: 0.375rem 0.75rem;
    background: var(--color-surface-primary);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    font-size: 0.8rem;
    color: var(--color-text-dim);
    transition: all 0.2s ease;
  }

  .skill-tag:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .skill-tag.learning {
    background: var(--color-surface-primary-subtle);
    border-color: var(--color-border-violet-subtle);
  }

  .skill-tag.learning:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .skills {
      padding: 4rem 1.5rem;
    }

    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
