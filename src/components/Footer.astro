---
const base = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <!-- Left: wordmark + tagline -->
    <div class="footer-brand">
      <a href={base} class="footer-logo">bl0xsmith</a>
      <p class="footer-tagline">Building at the intersection of AI, trading, and blockchain.</p>
    </div>

    <!-- Center: nav -->
    <nav class="footer-nav" aria-label="Footer navigation">
      <a href={base} class="footer-link">Home</a>
      <a href={`${base}projects`} class="footer-link">Projects</a>
      <a href={`${base}blog`} class="footer-link">Blog</a>
      <a href={`${base}about`} class="footer-link">About</a>
    </nav>

    <!-- Right: socials -->
    <div class="footer-socials">
      <!-- GitHub -->
      <a href="https://github.com/bl0xsmith" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="GitHub">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
        </svg>
      </a>
      <!-- X / Twitter -->
      <a href="https://x.com/bl0xsmith" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="X / Twitter">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
      <!-- Email -->
      <a href="mailto:hi@bl0xsmith.com" class="social-link" aria-label="Email">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
      </a>
    </div>
  </div>

  <div class="footer-bottom">
    <span class="footer-copy">&copy; {currentYear} bl0xsmith. Building in public.</span>
    <span class="footer-kbd-hint">
      Press
      <kbd>⌘</kbd><kbd>K</kbd>
      to navigate
    </span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--glass-border);
    background: var(--glass-bg);
    padding: 3rem 2rem 1.5rem;
    position: relative;
    z-index: 2;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: start;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-logo {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 200;
    letter-spacing: 0.3em;
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-logo:hover {
    color: var(--color-primary);
  }

  .footer-tagline {
    font-size: 0.8rem;
    color: var(--color-text-dim);
    line-height: 1.5;
    max-width: 220px;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
  }

  .footer-link {
    font-size: 0.875rem;
    color: var(--color-text-dim);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-link:hover {
    color: var(--color-text);
  }

  .footer-socials {
    display: flex;
    gap: 1rem;
    justify-content: flex-end;
    align-items: center;
  }

  .social-link {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-dim);
    border: 1px solid var(--glass-border);
    border-radius: 0.5rem;
    background: var(--glass-bg);
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .social-link:hover {
    color: var(--color-text);
    border-color: var(--glass-border-hover);
    background: var(--glass-bg-hover);
  }

  .footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    padding-top: 1.5rem;
    border-top: 1px solid var(--glass-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer-copy {
    font-size: 0.75rem;
    color: var(--color-text-dim);
  }

  .footer-kbd-hint {
    font-size: 0.75rem;
    color: var(--color-text-dim);
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  kbd {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.1rem 0.35rem;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0.25rem;
    font-size: 0.7rem;
    font-family: var(--font-body);
    color: var(--color-text-dim);
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .footer-brand {
      align-items: center;
    }

    .footer-tagline {
      max-width: 100%;
    }

    .footer-socials {
      justify-content: center;
    }

    .footer-kbd-hint {
      display: none;
    }
  }
</style>
