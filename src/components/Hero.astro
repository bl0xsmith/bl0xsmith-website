---
// Hero section - Professional dark glassmorphism
const base = import.meta.env.BASE_URL;
---

<section class="hero">
  <div class="hero-content">
    <h1 class="hero-title">
      <div class="greeting">Hello, I'm</div>
      <span class="title-text">bl0xsmith</span>
    </h1>
    <div class="greeting">I build at the intersection of</div>

    <p class="hero-subtitle">
      <span class="typewriter-wrap">
        <span class="typewriter" id="typewriter"></span><span class="cursor">|</span>
      </span>
    </p>

    <p class="hero-description">
      I'm bl0xsmith. I have a passion for building automated money-moving systems. Currently I'm building Metatron Automata, an agentic automated trading platform
      I run across crypto, forex, equities, and perps. By day I build trading and yield-earning infrastructure at one of the
      largest self-custody wallets in the crypto industry.
    </p>

    <div class="hero-buttons">
      <a href={`${base}projects`} class="btn btn-primary">
        <span>View Projects</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
      <a href={`${base}blog`} class="btn btn-secondary">
        <span>Read Blog</span>
      </a>
    </div>

    <!-- Status chips -->
    <div class="status-strip">
      <span class="status-chip status-chip--metatron">
        <span class="status-icon">
          <img
            src={`${base}images/metatron-mark.svg`}
            alt=""
            width="20"
            height="20"
            loading="lazy"
            decoding="async"
          />
        </span>
        Building Metatron Automata
      </span>
      <span class="status-chip status-chip--rust">
        <span class="status-icon status-icon-emoji" aria-hidden="true">🦀</span>
        Learning Rust
      </span>
    </div>

    <!-- Tech stack badges -->
    <div class="tech-stack">
      <span class="tech-badge">TypeScript</span>
      <span class="tech-badge">Node.js</span>
      <span class="tech-badge">NestJS</span>
      <span class="tech-badge">AI</span>
      <span class="tech-badge">Ethereum</span>
      <span class="tech-badge">Web3</span>
      <span class="tech-badge">Rust</span>
    </div>
  </div>

  <!-- Decorative elements -->
  <div class="hero-decoration">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: calc(var(--nav-height) + 2rem) 2rem 4rem;
  }

  .hero-content {
    text-align: center;
    z-index: 10;
    max-width: 800px;
    animation: fadeInUp 0.8s ease-out;
  }

  .greeting {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-text-dim);
    margin-bottom: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 12vw, 7rem);
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .title-text {
    background: linear-gradient(135deg, var(--color-text) 20%, var(--color-primary) 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Typewriter */
  .hero-subtitle {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    color: var(--color-text);
    margin-bottom: 1.5rem;
    font-weight: 500;
    min-height: 2.2em;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .typewriter-wrap {
    display: inline-flex;
    align-items: center;
    gap: 2px;
  }

  .cursor {
    color: var(--color-primary);
    animation: blink 0.9s step-end infinite;
    font-weight: 300;
    line-height: 1;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .hero-description {
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    color: var(--color-text-dim);
    margin-bottom: 2.5rem;
    line-height: 1.7;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    font-size: 1rem;
    font-weight: 600;
    font-family: var(--font-body);
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
    box-shadow: 0 4px 14px rgba(79, 101, 245, 0.18);
  }

  .btn-primary:hover {
    background: var(--color-primary-dark);
    box-shadow: 0 6px 20px rgba(79, 101, 245, 0.28);
  }

  .btn-primary svg {
    transition: transform 0.2s ease;
  }

  .btn-primary:hover svg {
    transform: translateX(4px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    background: var(--color-surface-primary);
    border-color: var(--color-primary);
  }

  /* Status chips */
  .status-strip {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .status-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.875rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 2rem;
    font-size: 0.8rem;
    color: var(--color-text-dim);
    font-family: var(--font-body);
    letter-spacing: 0.02em;
  }

  .status-chip--metatron {
    border-left: 2px solid var(--color-primary);
    padding-left: 0.65rem;
  }

  .status-chip--rust {
    border-left: 2px solid #f59e0b;
    padding-left: 0.65rem;
  }

  .status-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    animation: pulse-status-icon 2s ease-in-out infinite;
  }

  .status-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .status-icon-emoji {
    font-size: 1.1em;
    line-height: 1;
  }

  @keyframes pulse-status-icon {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.72; }
  }

  /* Tech badges */
  .tech-stack {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .tech-badge {
    padding: 0.5rem 1rem;
    background: var(--color-surface-primary);
    border: 1px solid var(--color-border);
    border-radius: 2rem;
    font-size: 0.875rem;
    color: var(--color-text-dim);
    transition: all 0.2s ease;
  }

  .tech-badge:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  /* Decorative glows */
  .hero-decoration {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.06;
  }

  .glow-1 {
    width: 400px;
    height: 400px;
    background: var(--color-primary);
    top: 10%;
    left: 10%;
    animation: float 8s ease-in-out infinite;
  }

  .glow-2 {
    width: 300px;
    height: 300px;
    background: var(--color-primary);
    bottom: 20%;
    right: 10%;
    animation: float 6s ease-in-out infinite reverse;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(20px, -20px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .glow-1, .glow-2 { animation: none; }
    .hero-content { animation: none; }
    .cursor { animation: none; }
    .status-icon { animation: none; }
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: calc(var(--nav-height) + 3rem);
    }

    .hero-buttons {
      flex-direction: column;
      align-items: center;
    }

    .btn {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }
  }
</style>

<script>
  const PHRASES = [
    'Perpetuals Trading Infrastructure',
    'AI Agent Systems',
    'DeFi Protocol Engineering',
    'Rust Engineering',
    'Node.js Engineering',
  ];

  let typewriterTimer: ReturnType<typeof setTimeout> | null = null;

  function clearTypewriterTimer() {
    if (typewriterTimer !== null) {
      clearTimeout(typewriterTimer);
      typewriterTimer = null;
    }
  }

  function initTypewriter() {
    const el = document.getElementById('typewriter');
    if (!el) return;

    clearTypewriterTimer();

    const node = el; // narrowed, non-null

    let phraseIdx = 0;
    let charIdx = 0;
    let deleting = false;
    let paused = false;

    function schedule(next: () => void, ms: number) {
      clearTypewriterTimer();
      typewriterTimer = setTimeout(next, ms);
    }

    function tick() {
      const phrase = PHRASES[phraseIdx]!;

      if (paused) {
        paused = false;
        deleting = true;
        schedule(tick, 400);
        return;
      }

      if (!deleting) {
        node.textContent = phrase.slice(0, charIdx + 1);
        charIdx++;
        if (charIdx === phrase.length) {
          paused = true;
          schedule(tick, 2000);
          return;
        }
        schedule(tick, 60);
      } else {
        node.textContent = phrase.slice(0, charIdx - 1);
        charIdx--;
        if (charIdx === 0) {
          deleting = false;
          phraseIdx = (phraseIdx + 1) % PHRASES.length;
          schedule(tick, 300);
          return;
        }
        schedule(tick, 30);
      }
    }

    tick();
  }

  document.addEventListener('astro:page-load', initTypewriter);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTypewriter);
  } else {
    initTypewriter();
  }
</script>
